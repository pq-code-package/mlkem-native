diff --git a/crypto/fipsmodule/ml_kem/importer.sh b/crypto/fipsmodule/ml_kem/importer.sh
index 8624bfdda..1deb796dc 100755
--- a/crypto/fipsmodule/ml_kem/importer.sh
+++ b/crypto/fipsmodule/ml_kem/importer.sh
@@ -127,29 +127,13 @@ cp $TMP/mlkem/mlkem_native.h $SRC
 echo "Fixup include paths"
 sed "${SED_I[@]}" 's/#include "src\/\([^"]*\)"/#include "\1"/' $SRC/mlkem_native_bcm.c
 
-echo "Fixup AArch64 and x86_64 assembly backend to use s2n-bignum macros"
-for file in $SRC/native/aarch64/src/*.S $SRC/native/x86_64/src/*.S; do
-  echo "Processing $file"
-  tmp_file=$(mktemp)
-
-  backend_define=$(if [[ "$file" == *"aarch64"* ]]; then echo "MLK_ARITH_BACKEND_AARCH64"; else echo "MLK_ARITH_BACKEND_X86_64_DEFAULT"; fi)
-
-  # Flatten multiline preprocessor directives, then process with unifdef
-  sed -e ':a' -e 'N' -e '$!ba' -e 's/\\\n/ /g' "$file" | \
-    unifdef -D$backend_define -UMLK_CONFIG_MULTILEVEL_NO_SHARED -DMLK_CONFIG_MULTILEVEL_WITH_SHARED > "$tmp_file"
-  mv "$tmp_file" "$file"
-
-  # Replace common.h include and assembly macros
-  s2n_header=$(if [[ "$file" == *"aarch64"* ]]; then echo "_internal_s2n_bignum_arm.h"; else echo "_internal_s2n_bignum_x86_att.h"; fi)
-  sed "${SED_I[@]}" "s/#include \"\.\.\/\.\.\/\.\.\/common\.h\"/#include \"$s2n_header\"/" "$file"
-
-  func_name=$(grep -o '\.global MLK_ASM_NAMESPACE(\([^)]*\))' "$file" | sed 's/\.global MLK_ASM_NAMESPACE(\([^)]*\))/\1/')
-  if [ -n "$func_name" ]; then
-    sed "${SED_I[@]}" "s/\.global MLK_ASM_NAMESPACE($func_name)/        S2N_BN_SYM_VISIBILITY_DIRECTIVE(mlkem_$func_name)\n        S2N_BN_SYM_PRIVACY_DIRECTIVE(mlkem_$func_name)/" "$file"
-    sed "${SED_I[@]}" "s/MLK_ASM_FN_SYMBOL($func_name)/S2N_BN_SYMBOL(mlkem_$func_name):/" "$file"
-    sed "${SED_I[@]}" "s/MLK_ASM_FN_SIZE($func_name)/S2N_BN_SIZE_DIRECTIVE(mlkem_$func_name)/" "$file"
-  fi
-done
+# Note: the per-.S rewriting that previously bridged mlkem-native's
+# MLK_ASM_NAMESPACE / MLK_ASM_FN_SYMBOL / MLK_ASM_FN_SIZE macros to
+# s2n-bignum's S2N_BN_* directives, swapped out the asm-side common.h
+# include, and unifdef'ed the asm sources is no longer required.
+# The bridging now happens at preprocessor time via overrides installed
+# in mlkem_native_config.h, which the asm sources reach through their
+# `#include "../../../common.h"` chain.
 
 echo "Remove temporary artifacts ..."
 rm -rf $TMP
diff --git a/crypto/fipsmodule/ml_kem/mlkem_native_config.h b/crypto/fipsmodule/ml_kem/mlkem_native_config.h
index 6df118024..648838af2 100644
--- a/crypto/fipsmodule/ml_kem/mlkem_native_config.h
+++ b/crypto/fipsmodule/ml_kem/mlkem_native_config.h
@@ -109,6 +109,45 @@ static MLK_INLINE void *mlk_memset(void *s, int c, size_t n) {
 #define MLK_CONFIG_NO_ASM
 #endif
 
+// ---------------------------------------------------------------------------
+// Bridge mlkem-native's assembly-declaration macros to s2n-bignum's
+// symbol / visibility / privacy / size directives.
+//
+// mlkem-native (>= the version with overridable MLK_ASM_* macros) leaves
+// each of these undefined when the integrator provides their own. Defining
+// them here in the integrator config replaces the per-.S sed rewrites the
+// importer used to perform.
+//
+// Visible to both C compilation (via mlkem_native.h / common.h) and the
+// assembler (via the .S files' `#include "../../../common.h"` ->
+// common.h -> MLK_CONFIG_FILE -> this file).
+// ---------------------------------------------------------------------------
+
+#if defined(__ASSEMBLER__)
+#if defined(__aarch64__) || defined(_M_ARM64)
+#include "_internal_s2n_bignum_arm.h"
+#elif defined(__x86_64__) || defined(_M_X64)
+#include "_internal_s2n_bignum_x86_att.h"
+#endif
+#endif // __ASSEMBLER__
+
+// Suppress mlkem-native's Apple leading-underscore handling. S2N_BN_SYMBOL
+// already takes care of platform-specific symbol decoration, so the
+// namespaced form is just `mlkem_<sym>` on every target.
+#define MLK_ASM_NAMESPACE(sym) mlkem_##sym
+
+// `.global mlkem_<sym>` (plus optional privacy directive). The trailing
+// semicolon separates from any directive emitted on the same logical line.
+#define MLK_ASM_FN_GLOBAL(sym)                                \
+  S2N_BN_SYM_VISIBILITY_DIRECTIVE(MLK_ASM_NAMESPACE(sym));    \
+  S2N_BN_SYM_PRIVACY_DIRECTIVE(MLK_ASM_NAMESPACE(sym))
+
+// Function label, with platform-correct decoration.
+#define MLK_ASM_FN_SYMBOL(sym) S2N_BN_SYMBOL(MLK_ASM_NAMESPACE(sym)):
+
+// Function size directive (no-op on Mach-O).
+#define MLK_ASM_FN_SIZE(sym) S2N_BN_SIZE_DIRECTIVE(MLK_ASM_NAMESPACE(sym))
+
 // Enable AArch64 arithmetic backend and set path
 #define MLK_CONFIG_USE_NATIVE_BACKEND_ARITH
 #define MLK_CONFIG_ARITH_BACKEND_FILE "../mlkem_native_backend.h"
