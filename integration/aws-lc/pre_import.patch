diff --git a/crypto/fipsmodule/ml_kem/importer.sh b/crypto/fipsmodule/ml_kem/importer.sh
--- a/crypto/fipsmodule/ml_kem/importer.sh
+++ b/crypto/fipsmodule/ml_kem/importer.sh
@@ -134,9 +134,15 @@
 
   backend_define=$(if [[ "$file" == *"aarch64"* ]]; then echo "MLK_ARITH_BACKEND_AARCH64"; else echo "MLK_ARITH_BACKEND_X86_64_DEFAULT"; fi)
 
-  # Flatten multiline preprocessor directives, then process with unifdef
+  # Flatten multiline preprocessor directives, then process with unifdef.
+  # The reduced-API macros (MLK_CONFIG_NO_{KEYPAIR,ENCAPS,DECAPS}_API) are
+  # never set in the AWS-LC import, so mark them undefined; otherwise unifdef
+  # leaves the enclosing MLK_ARITH_BACKEND_AARCH64 guard in place, which then
+  # evaluates to false (the include is rewritten to s2n-bignum, so the backend
+  # macro is undefined at build time) and drops the assembly symbol.
   sed -e ':a' -e 'N' -e '$!ba' -e 's/\\\n/ /g' "$file" | \
-    unifdef -D$backend_define -UMLK_CONFIG_MULTILEVEL_NO_SHARED -DMLK_CONFIG_MULTILEVEL_WITH_SHARED > "$tmp_file"
+    unifdef -D$backend_define -UMLK_CONFIG_MULTILEVEL_NO_SHARED -DMLK_CONFIG_MULTILEVEL_WITH_SHARED \
+            -UMLK_CONFIG_NO_KEYPAIR_API -UMLK_CONFIG_NO_ENCAPS_API -UMLK_CONFIG_NO_DECAPS_API > "$tmp_file"
   mv "$tmp_file" "$file"
 
   # Replace common.h include and assembly macros
@@ -151,6 +157,48 @@
   fi
 done
 
+# Rewrite asm filenames in AWS-LC's crypto/fipsmodule/CMakeLists.txt to match the names exported by the imported mlkem-native tree. Remove once AWS-LC lists the post-unification filenames directly.
+CMAKE=../CMakeLists.txt
+if [ -f "$CMAKE" ] && grep -q 'aarch64/src/ntt\.S' "$CMAKE"; then
+    CMAKE_RENAMES=(
+        'aarch64/src/intt\.S|aarch64/src/intt_aarch64_asm.S'
+        'aarch64/src/ntt\.S|aarch64/src/ntt_aarch64_asm.S'
+        'aarch64/src/poly_mulcache_compute_asm\.S|aarch64/src/poly_mulcache_compute_aarch64_asm.S'
+        'aarch64/src/poly_reduce_asm\.S|aarch64/src/poly_reduce_aarch64_asm.S'
+        'aarch64/src/poly_tobytes_asm\.S|aarch64/src/poly_tobytes_aarch64_asm.S'
+        'aarch64/src/poly_tomont_asm\.S|aarch64/src/poly_tomont_aarch64_asm.S'
+        'aarch64/src/polyvec_basemul_acc_montgomery_cached_asm_k2\.S|aarch64/src/polyvec_basemul_acc_montgomery_cached_k2_aarch64_asm.S'
+        'aarch64/src/polyvec_basemul_acc_montgomery_cached_asm_k3\.S|aarch64/src/polyvec_basemul_acc_montgomery_cached_k3_aarch64_asm.S'
+        'aarch64/src/polyvec_basemul_acc_montgomery_cached_asm_k4\.S|aarch64/src/polyvec_basemul_acc_montgomery_cached_k4_aarch64_asm.S'
+        'aarch64/src/rej_uniform_asm\.S|aarch64/src/rej_uniform_aarch64_asm.S'
+        'x86_64/src/intt\.S|x86_64/src/intt_avx2_asm.S'
+        'x86_64/src/ntt\.S|x86_64/src/ntt_avx2_asm.S'
+        'x86_64/src/mulcache_compute\.S|x86_64/src/poly_mulcache_compute_avx2_asm.S'
+        'x86_64/src/nttfrombytes\.S|x86_64/src/nttfrombytes_avx2_asm.S'
+        'x86_64/src/ntttobytes\.S|x86_64/src/ntttobytes_avx2_asm.S'
+        'x86_64/src/nttunpack\.S|x86_64/src/nttunpack_avx2_asm.S'
+        'x86_64/src/reduce\.S|x86_64/src/reduce_avx2_asm.S'
+        'x86_64/src/tomont\.S|x86_64/src/tomont_avx2_asm.S'
+        'x86_64/src/polyvec_basemul_acc_montgomery_cached_asm_k2\.S|x86_64/src/polyvec_basemul_acc_montgomery_cached_k2_avx2_asm.S'
+        'x86_64/src/polyvec_basemul_acc_montgomery_cached_asm_k3\.S|x86_64/src/polyvec_basemul_acc_montgomery_cached_k3_avx2_asm.S'
+        'x86_64/src/polyvec_basemul_acc_montgomery_cached_asm_k4\.S|x86_64/src/polyvec_basemul_acc_montgomery_cached_k4_avx2_asm.S'
+        'x86_64/src/rej_uniform_asm\.S|x86_64/src/rej_uniform_avx2_asm.S'
+        'x86_64/src/poly_compress_d4\.S|x86_64/src/poly_compress_d4_avx2_asm.S'
+        'x86_64/src/poly_compress_d5\.S|x86_64/src/poly_compress_d5_avx2_asm.S'
+        'x86_64/src/poly_compress_d10\.S|x86_64/src/poly_compress_d10_avx2_asm.S'
+        'x86_64/src/poly_compress_d11\.S|x86_64/src/poly_compress_d11_avx2_asm.S'
+        'x86_64/src/poly_decompress_d4\.S|x86_64/src/poly_decompress_d4_avx2_asm.S'
+        'x86_64/src/poly_decompress_d5\.S|x86_64/src/poly_decompress_d5_avx2_asm.S'
+        'x86_64/src/poly_decompress_d10\.S|x86_64/src/poly_decompress_d10_avx2_asm.S'
+        'x86_64/src/poly_decompress_d11\.S|x86_64/src/poly_decompress_d11_avx2_asm.S'
+    )
+    for pair in "${CMAKE_RENAMES[@]}"; do
+        old="${pair%|*}"
+        new="${pair#*|}"
+        sed "${SED_I[@]}" -E "s|${old}|${new}|g" "$CMAKE"
+    done
+fi
+
 echo "Remove temporary artifacts ..."
 rm -rf $TMP
 
